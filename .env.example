# ==========================================
# ENV TEMPLATE FOR LAPOR-INFRASTRUKTUR
# Copy this file to apps/backend/.env and adjust
# ==========================================

# Database URL for PostgreSQL connection
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/lapor_infra?schema=public"

# JWT Secret Key for authenticating user sessions
JWT_SECRET="your_secret_key_change_me_in_production_12345"

# Port on which the backend server runs (default: 3000)
PORT=3000
